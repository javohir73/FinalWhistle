# Copy to .env (backend) and frontend/.env.local as noted. Never commit real secrets.

# ---- Backend (FastAPI) ----
# Local docker-compose Postgres. Override with your hosted DB URL in production.
DATABASE_URL=postgresql+psycopg2://wc26:wc26@localhost:5432/wc26
# Shared secret guarding POST /api/internal/recompute (the cron job sends this).
RECOMPUTE_TOKEN=dev-recompute-token
# Comma-separated allowed frontend origins for CORS.
CORS_ORIGINS=http://localhost:3000
# REQUIRED for local dev (both default to production-safe values otherwise):
# - COOKIE_SECURE=false: localhost is plain http; with the Secure flag set the
#   session cookie is dropped (Safari always; sign-in appears to work but never
#   sticks). Keep "true" in production.
# - ENVIRONMENT=development: relaxes the production-only Origin requirement so
#   curl/tests work without an Origin header.
ENVIRONMENT=development
COOKIE_SECURE=false
# Optional overrides:
# APP_NAME=FinalWhistle
# MODEL_VERSION=poisson-elo-v0.1

# ---- Live in-game scores ----
# Live updates are active only when LIVE_MODE_ENABLED=true AND the selected
# provider's key is set (otherwise a safe no-op). The board's 30s poll drives
# refreshes — no cron required.
LIVE_MODE_ENABLED=false
# Provider: only "football_data" has ingestion wired. "api_football" is
# config-only scaffolding (selecting it skips loudly until ingestion is built).
LIVE_PROVIDER=football_data
# football-data.org — FREE key at https://www.football-data.org/client/register
# Free tier delays scores and omits the live minute (estimated locally from
# kickoff); the real official minute needs a paid tier.
FOOTBALL_DATA_API_KEY=
# API-Football (api-sports.io) — carries the real live minute. Config only for
# now; ingestion not yet implemented.
# API_FOOTBALL_API_KEY=

# ---- Frontend (Next.js) — put this in frontend/.env.local ----
# Base URL of the backend API the browser calls.
NEXT_PUBLIC_API_URL=http://localhost:8000
