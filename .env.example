# Copy to .env (backend) and frontend/.env.local as noted. Never commit real secrets.

# ---- Backend (FastAPI) ----
# Local docker-compose Postgres. Override with your hosted DB URL in production.
DATABASE_URL=postgresql+psycopg2://wc26:wc26@localhost:5432/wc26
# Shared secret guarding POST /api/internal/recompute (the cron job sends this).
RECOMPUTE_TOKEN=dev-recompute-token
# Comma-separated allowed frontend origins for CORS. The www/apex sibling of each
# entry is auto-allowed, and the same list also powers the Origin (CSRF) guard.
CORS_ORIGINS=http://localhost:3000
# Optional anchored regex admitting extra origins (e.g. this project's Vercel
# previews). Leave BLANK in production — a loose *.vercel.app pattern is a CSRF
# hole. Example (set only on a preview/staging service):
# CORS_PREVIEW_REGEX=^https://fifa-wc26-prediction-[a-z0-9-]+\.vercel\.app$
# REQUIRED for local dev (both default to production-safe values otherwise):
# - COOKIE_SECURE=false: localhost is plain http; with the Secure flag set the
#   session cookie is dropped (Safari always; sign-in appears to work but never
#   sticks). Keep "true" in production.
# - ENVIRONMENT=development: relaxes the production-only Origin requirement so
#   curl/tests work without an Origin header.
ENVIRONMENT=development
COOKIE_SECURE=false
# Optional overrides:
# APP_NAME=FinalWhistle
# MODEL_VERSION=poisson-elo-v0.1

# ---- Transactional email (password reset, email verification) ----
# EMAIL_PROVIDER=console (default) logs links and makes no network call — fine for
# local dev. Set to "resend" + EMAIL_API_KEY in production to actually send. An
# empty key falls back to console (never crashes the auth flow).
# EMAIL_PROVIDER=console
# EMAIL_API_KEY=
# EMAIL_FROM=FinalWhistle <noreply@finalwhistle.app>
# Base URL used to build links in emails — must be an allowed origin.
# PUBLIC_BASE_URL=https://fifa-wc26-prediction.vercel.app

# ---- Live in-game scores ----
# Live updates are active only when LIVE_MODE_ENABLED=true AND the selected
# provider's key is set (otherwise a safe no-op). The board's 30s poll drives
# refreshes — no cron required.
LIVE_MODE_ENABLED=false
# Provider: "football_data" or "api_football" (both have ingestion wired).
#   football_data : free tier; scores delayed, live minute ESTIMATED from kickoff
#   api_football  : real OFFICIAL live minute (status.elapsed) — best for real-time
LIVE_PROVIDER=football_data
# football-data.org — FREE key at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=
# API-Football (api-sports.io) — real-time. Key at https://dashboard.api-sports.io
# (free tier includes the live minute, 100 req/day). To use it, also set
# LIVE_PROVIDER=api_football above.
# API_FOOTBALL_API_KEY=

# ---- Frontend (Next.js) — put this in frontend/.env.local ----
# Base URL of the backend API the browser calls.
NEXT_PUBLIC_API_URL=http://localhost:8000
